APP_NAME="SGC F&C Chile SPA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/FYC-sgc/public

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CL

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Base de datos ────────────────────────────────────────────
# Conecta a la BD existente del SGC — NO ejecutar migraciones
# que modifiquen tablas sgc_* existentes
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cfc48507_epp
DB_USERNAME=root
DB_PASSWORD=

# ── Sesión ───────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false   # cambiar a true en producción con HTTPS

# ── Cache ────────────────────────────────────────────────────
CACHE_STORE=file

# ── Cola ─────────────────────────────────────────────────────
QUEUE_CONNECTION=sync
